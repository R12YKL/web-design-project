{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "routes": [
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/history",
      "dest": "/history.html"
    },
    {
      "src": "/hardware",
      "dest": "/hardware.html"
    },
    {
      "src": "/python",
      "dest": "/Python.html"
    },
    {
      "src": "/logic",
      "dest": "/logic.html"
    },
    {
      "src": "/ethics",
      "dest": "/ethics.html"
    }
  ]
}
